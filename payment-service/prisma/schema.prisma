// Prisma schema para el servicio de pagos
// Definición de modelos para comerciantes, transacciones y liquidaciones

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MerchantStatus {
  active
  inactive
}

enum TransactionStatus {
  pending
  approved
  rejected
  failed
  completed
}

enum TransactionType {
  payin
  payout
}

enum Currency {
  GTQ
  COP
  USD
}

enum SettlementStatus {
  pending
  processed
  paid
}

model Merchant {
  id        String         @id @default(uuid()) @db.Uuid
  name      String         @db.VarChar(150)
  email     String         @unique @db.VarChar(320)
  apiKey    String         @unique @map("api_key")
  status    MerchantStatus
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]

  @@map("merchants")
}

model Transaction {
  id                    String                 @id @default(uuid()) @db.Uuid
  merchantId            String                 @map("merchant_id") @db.Uuid
  amount                Decimal                @db.Decimal(12, 2)
  currency              Currency
  type                  TransactionType
  status                TransactionStatus
  reference             String                 @unique @db.VarChar(19)
  metadata              Json?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  merchant              Merchant               @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  settlementTransaction SettlementTransaction?

  @@index([merchantId, status, createdAt])
  @@index([merchantId, type, createdAt])
  @@index([merchantId, createdAt])
  @@map("transactions")
}

model Settlement {
  id               String           @id @default(uuid()) @db.Uuid
  merchantId       String           @map("merchant_id") @db.Uuid
  totalAmount      Decimal          @map("total_amount") @db.Decimal(14, 2)
  transactionCount Int              @map("transaction_count")
  status           SettlementStatus
  periodStart      DateTime         @map("period_start")
  periodEnd        DateTime         @map("period_end")
  createdAt        DateTime         @default(now()) @map("created_at")

  merchant               Merchant                @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  settlementTransactions SettlementTransaction[]

  @@index([merchantId, status, createdAt])
  @@index([merchantId, periodStart, periodEnd])
  @@map("settlements")
}

model SettlementTransaction {
  settlementId  String @map("settlement_id") @db.Uuid
  transactionId String @unique @map("transaction_id") @db.Uuid

  settlement  Settlement  @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@id([settlementId, transactionId])
  @@map("settlement_transactions")
}
